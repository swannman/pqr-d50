// Copy to secrets.h and fill in. secrets.h is gitignored — never commit real creds.
#pragma once

#define WIFI_SSID    "your-ssid"
#define WIFI_PASS    "your-password"

// From Grafana Cloud -> InfluxDB "Send Metrics":
#define INFLUX_URL   "https://influx-prod-XX-prod-REGION.grafana.net/api/v1/push/influx/write"
#define INFLUX_USER  "your-instance-id"
#define INFLUX_TOKEN "glc_xxxxxxxx"

// Grafana Cloud Loki "Send Logs": URL + numeric user, token reuses INFLUX_TOKEN
#define LOKI_URL     "https://logs-prod-XXX.grafana.net/loki/api/v1/push"
#define LOKI_USER    "your-loki-instance-id"
