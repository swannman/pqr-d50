{
  "__inputs": [
    {
      "name": "DS_PROM",
      "label": "Prometheus / Grafana Cloud Metrics",
      "description": "The Prometheus (Mimir) datasource your D50 metrics land in.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Disturbances",
        "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
        "enable": true,
        "iconColor": "red",
        "expr": "pqr_d50_event_magnitude{unit=~\"$unit\"}",
        "titleFormat": "{{type}}",
        "textFormat": "{{type}} ({{value}} V)",
        "tagKeys": "type"
      }
    ]
  },
  "editable": true,
  "title": "PQR D50 - Mains Power Quality",
  "uid": "pqr-d50-mains",
  "tags": ["power", "pqr-d50"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "unit",
        "label": "Unit",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
        "query": "label_values(pqr_d50_hot, unit)",
        "refresh": 2,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Line voltage (Hot)  -  ANSI C84.1 normal 114-126 V",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "min": 100,
          "max": 132,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": true,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 110 },
              { "color": "green", "value": 114 },
              { "color": "orange", "value": 126 },
              { "color": "red", "value": 127 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "pqr_d50_hot{unit=~\"$unit\"}",
          "legendFormat": "Hot {{unit}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Neutral-to-ground voltage (wiring health)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "pqr_d50_neu{unit=~\"$unit\"}",
          "legendFormat": "Neu {{unit}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latest line voltage",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 114 },
              { "color": "red", "value": 127 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "pqr_d50_hot{unit=~\"$unit\"}",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Power failures (range)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "count_over_time(pqr_d50_event_magnitude{unit=~\"$unit\", type=\"power_failure\"}[$__range])",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent disturbances",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 17 },
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" },
            "properties": [ { "id": "displayName", "value": "Magnitude (V)" }, { "id": "unit", "value": "volt" } ] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "pqr_d50_event_magnitude{unit=~\"$unit\"}",
          "format": "table",
          "instant": false
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "__name__": true, "job": true, "instance": true } } }
      ]
    }
  ]
}
